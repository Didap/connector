# Auth
# Generate hash: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" 'your-password'
CONNECTOR_PASSWORD_HASH=
# Random 32+ bytes hex: openssl rand -hex 32
SESSION_SECRET=

# Database (SQLite file path; Coolify mounts /app/data)
DATABASE_URL=file:./data/conductor.db

# Per-product webhook secrets — env var name is referenced in each Action row
DITTO_AGENT_SECRET=

# Optional
NODE_ENV=development
